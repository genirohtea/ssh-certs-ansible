---
# MANAGED BY TEMPLATE (copied 2026-05-23 from 6bed4) — do not edit. Sync from the source template; user must manage overwrites.
exclude_paths:
  # default paths
  - '.cache/'
  - '.github/'
  - 'test/fixtures/formatting-before/'
  - 'test/fixtures/formatting-prettier/'

  # The "converge" and "reset" playbooks use import_playbook in
  # conjunction with the "env" lookup plugin, which lets the
  # syntax check of ansible-lint fail.
  - 'molecule/**/converge.yml'
  - 'molecule/**/prepare.yml'
  - 'molecule/**/reset.yml'
  - '**/test.yml'

  # The file was generated by galaxy ansible - don't mess with it.
  - 'galaxy.yml'

skip_list:
  - 'fqcn-builtins'
  - var-naming[no-role-prefix]
  - yaml # We will use yamllint instead

warn_list:
  - yaml[line-length]

use_default_rules: true

# Install collections from requirements.yml so syntax-check can resolve
# community.general.* modules.
offline: false

# END MANAGED TEMPLATE — add custom content below
